### NYDL Backend API Test Collection
### REST Client extension (VS Code) format. Matches the existing logout.rest convention.
### Usage: run requests top to bottom within a module - login first to populate {{accessToken}},
### then paste real Mongo ObjectIds from your database into the @variables below as needed.

@baseUrl = http://localhost:3000/api/v1
@accessToken = REPLACE_WITH_TOKEN_FROM_LOGIN_RESPONSE
@userId = REPLACE_WITH_USER_ID
@courseId = REPLACE_WITH_COURSE_ID
@cohortId = REPLACE_WITH_COHORT_ID
@studentId = REPLACE_WITH_STUDENT_PROFILE_ID
@instructorId = REPLACE_WITH_INSTRUCTOR_PROFILE_ID
@mentorId = REPLACE_WITH_MENTOR_PROFILE_ID
@teamId = REPLACE_WITH_TEAM_ID
@enrollmentId = REPLACE_WITH_ENROLLMENT_ID
@sessionId = REPLACE_WITH_SESSION_ID
@assignmentId = REPLACE_WITH_ASSIGNMENT_ID
@submissionId = REPLACE_WITH_SUBMISSION_ID
@resourceId = REPLACE_WITH_RESOURCE_ID
@announcementId = REPLACE_WITH_ANNOUNCEMENT_ID
@notificationId = REPLACE_WITH_NOTIFICATION_ID
@paymentId = REPLACE_WITH_PAYMENT_ID
@certificateId = REPLACE_WITH_CERTIFICATE_ID
@moduleId = REPLACE_WITH_MODULE_ID

###############################################################################
# AUTH
###############################################################################

### Signup (student, default role)
POST {{baseUrl}}/auth/signup
Content-Type: application/json

{
  "name": "Test Student",
  "email": "test.student@example.com",
  "password": "Password123!",
  "role": "student"
}

### Signup - validation error (short password)
POST {{baseUrl}}/auth/signup
Content-Type: application/json

{
  "name": "Test Student",
  "email": "bad-email",
  "password": "123",
  "role": "student"
}

### Login
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "test.student@example.com",
  "password": "Password123!"
}

### Login - invalid credentials (expect 401)
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "test.student@example.com",
  "password": "wrong-password"
}

### Refresh token (uses httpOnly cookie set by login; run in a client that persists cookies)
POST {{baseUrl}}/auth/refresh-token

### GitHub OAuth redirect (open in browser, not via REST client)
GET {{baseUrl}}/auth/github?from=http://localhost:5174

### Get profile (requires auth)
GET {{baseUrl}}/auth/profile
Authorization: Bearer {{accessToken}}

### Get profile - unauthorized (no token, expect 401)
GET {{baseUrl}}/auth/profile

### Update profile
PUT {{baseUrl}}/auth/profile
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Updated Name"
}

### Logout
POST {{baseUrl}}/auth/logout
Authorization: Bearer {{accessToken}}

